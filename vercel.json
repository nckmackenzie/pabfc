{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "member.nickmackenzie.co.ke" }],
      "destination": "/member/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pabfc.nickmackenzie.co.ke" }],
      "destination": "/app/:path*"
    }
  ]
}
